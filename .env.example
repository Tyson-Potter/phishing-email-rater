# Phishing Email Rater configuration.
# Copy this file to `.env` and uncomment / edit the variables you want to override.
# `.env` is gitignored so your secrets stay local.
#
# All variables are optional — sensible defaults are baked into the code.


# =============================================================================
# ML classifier (HuggingFace)
# =============================================================================

# HuggingFace Hub model ID. Any text-classification model with phishing/legit
# label semantics should work; if you swap to a model whose label names differ
# from the defaults below, update the label sets accordingly.
#
# To find newer models:  https://huggingface.co/models?search=phishing
# PHISHING_RATER_ML_MODEL=cybersectony/phishing-email-detection-distilbert_v2.4.1

# Comma-separated label names treated as "phishing" / "legitimate" by the
# aggregator. Defaults cover cybersectony's binary labels plus several common
# multi-label and human-readable variants, so most replacement models work
# without changes.
# PHISHING_RATER_ML_PHISHING_LABELS=LABEL_1,phishing,phishing_url,phishing_url_alt
# PHISHING_RATER_ML_LEGITIMATE_LABELS=LABEL_0,legitimate,legitimate_email,legitimate_url


# =============================================================================
# LLM analyzer
# =============================================================================

# Default backend is local Ollama (privacy-by-default — email content does not
# leave the machine). Override these to use a different OpenAI-compatible API.

# --- Local Ollama (default; uncomment only to override the model) ---
# PHISHING_RATER_LLM_BASE_URL=http://localhost:11434/v1
# PHISHING_RATER_LLM_API_KEY=ollama
# PHISHING_RATER_LLM_MODEL=llama3.2:3b

# --- OpenAI ---
# PHISHING_RATER_LLM_BASE_URL=https://api.openai.com/v1
# PHISHING_RATER_LLM_API_KEY=sk-your-openai-key-here
# PHISHING_RATER_LLM_MODEL=gpt-4o-mini

# --- Anthropic Claude (via an OpenAI-compat proxy such as litellm) ---
# PHISHING_RATER_LLM_BASE_URL=http://localhost:4000   # litellm proxy
# PHISHING_RATER_LLM_API_KEY=sk-anthropic-passthrough
# PHISHING_RATER_LLM_MODEL=claude-sonnet-4-6


# =============================================================================
# HuggingFace Hub privacy
# =============================================================================
# These are set with `setdefault` in code; uncomment only if you need to
# override (e.g. you actually want telemetry, or you want air-gapped operation
# after the model is cached).

# HF_HUB_DISABLE_TELEMETRY=1
# HF_HUB_DISABLE_IMPLICIT_TOKEN=1
# HF_HUB_DISABLE_PROGRESS_BARS=1
# HF_HUB_OFFLINE=1            # fully offline; cache only, no update checks
# TRANSFORMERS_OFFLINE=1
